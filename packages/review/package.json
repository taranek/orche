{
  "name": "@orche/review",
  "version": "0.0.14",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "taranek",
  "description": "Code review UI for orche",
  "repository": {
    "type": "git",
    "url": "https://github.com/taranek/orche.git",
    "directory": "packages/review"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "package": "pnpm build && electron-builder --publish never",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.orche.review",
    "productName": "orche-review",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!node_modules"
    ],
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@orche/shared": "workspace:*",
    "@pierre/diffs": "^1.1.3",
    "@tanstack/react-virtual": "^3.13.23",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^41.0.3",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.2.2",
    "vite": "^8.0.5",
    "vite-plugin-electron": "^0.29.1"
  }
}
