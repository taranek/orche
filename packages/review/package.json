{
  "name": "@orche/review",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "taranek",
  "description": "Code review UI for orche",
  "repository": {
    "type": "git",
    "url": "https://github.com/taranek/orche.git",
    "directory": "packages/review"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "package": "pnpm build && electron-builder --publish never",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.orche.review",
    "productName": "orche-review",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!node_modules"
    ],
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@orche/shared": "workspace:*",
    "chokidar": "^5.0.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
