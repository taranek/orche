{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "orche-review",
  "version": "0.0.1",
  "identifier": "com.orche.review",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "orche review",
        "width": 1200,
        "height": 720,
        "minWidth": 1200,
        "minHeight": 720,
        "titleBarStyle": "Overlay",
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../build/icons/32x32.png",
      "../build/icons/128x128.png",
      "../build/icon.icns",
      "../build/icon.ico"
    ]
  }
}
